{
  "version": 2,
  "installCommand": "npm install --prefer-offline",
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "15mb",
        "memory": 1024,
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/notion/sync-students",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/schedule-cache/refresh",
      "schedule": "5 6 * * *"
    }
  ]
}
